-- 1. What is the total amount each customer spent at the restaurant?
SELECT customer_id,
	SUM(menu.price) AS total_amount
FROM sales
JOIN menu
ON sales.product_id=menu.product_id
GROUP BY 1
-- 2. How many days has each customer visited the restaurant?
SELECT customer_id,
	COUNT(DISTINCT order_date) as total_days
FROM sales
GROUP BY 1
-- 3. What was the first item from the menu purchased by each customer?
WITH ranked_orders AS (SELECT customer_id,
	order_date,
    sales.product_id,
    product_name,
    RANK() OVER (PARTITION BY customer_id ORDER BY order_date) AS ranked_products
FROM sales
JOIN menu
ON sales.product_id=menu.product_id
)
SELECT customer_id,
	order_date,
    product_id,
    product_name
FROM ranked_orders
WHERE ranked_products = 1
-- 4. What is the most purchased item on the menu and how many times was it purchased by all customers?
SELECT sales.product_id,
	menu.product_name,
	COUNT(*) as total_orders
FROM sales
JOIN menu
ON sales.product_id=menu.product_id
GROUP BY 1,2
ORDER BY total_orders DESC
LIMIT 1
-- 5. Which item was the most popular for each customer?
WITH total_products_customer AS (SELECT customer_id,
	sales.product_id,
    product_name,
    COUNT(*) AS total_orders
FROM sales
JOIN menu
ON sales.product_id=menu.product_id
GROUP BY 1,2,3
)

,ranked AS (SELECT customer_id,
	product_name,
    total_orders,
    RANK() OVER (PARTITION BY customer_id ORDER BY total_orders DESC) AS ranked_products
FROM total_products_customer
)

SELECT ranked.*
FROM ranked
WHERE ranked_products = 1

-- 6. Which item was purchased first by the customer after they became a member?
WITH intermediate AS (SELECT sales.customer_id,
	sales.product_id,
    product_name,
    join_date,
    order_date,
    RANK() OVER (PARTITION BY sales.customer_id ORDER BY order_date ASC) AS product_rank
FROM sales
JOIN members
ON sales.customer_id=members.customer_id
JOIN menu
ON sales.product_id=menu.product_id
WHERE order_date >= join_date
)

SELECT *
FROM intermediate
WHERE product_rank = 1
-- 7. Which item was purchased just before the customer became a member?
WITH intermediate AS (SELECT sales.customer_id,
	sales.product_id,
    product_name,
    join_date,
    order_date,
    RANK() OVER (PARTITION BY sales.customer_id ORDER BY order_date DESC) AS product_rank
FROM sales
JOIN members
ON sales.customer_id=members.customer_id
JOIN menu
ON sales.product_id=menu.product_id
WHERE order_date < join_date
)

SELECT *
FROM intermediate
WHERE product_rank = 1

-- 8. What is the total items and amount spent for each member before they became a member?
SELECT sales.customer_id,
    COUNT(sales.product_id) AS total_items,
    SUM(menu.price) AS amount_spent
FROM sales
JOIN menu
ON sales.product_id=menu.product_id
JOIN members
ON sales.customer_id=members.customer_id
WHERE order_date < join_date
GROUP BY 1
-- 9.  If each $1 spent equates to 10 points and sushi has a 2x points multiplier - how many points would each customer have?
WITH points_calculation AS (SELECT customer_id,
	product_name,
    price,
    CASE WHEN product_name = 'sushi' THEN price*2*10
    ELSE price*10
    END AS points
FROM sales
JOIN menu
ON sales.product_id=menu.product_id
)

SELECT customer_id,
	SUM(points) AS total_points
FROM points_calculation
GROUP BY 1
ORDER BY 2 DESC
-- 10. In the first week after a customer joins the program (including their join date) they earn 2x points on all items, not just sushi - how many points do customer A and B have at the end of January?
WITH points_calculated AS (SELECT sales.customer_id,
	product_name,
    price,
    order_date,
    CASE WHEN order_date > join_date AND order_date - join_date <= 7
    THEN price*10*2
    WHEN product_name = 'sushi'
    THEN price*10*2
    ELSE price*10
    END AS points
FROM sales
JOIN menu
ON sales.product_id=menu.product_id
JOIN members
ON sales.customer_id=members.customer_id
WHERE order_date < '2021-02-01'
)

SELECT customer_id,
	SUM(points) AS total_points
FROM points_calculated
GROUP BY 1


-- JOIN all the things
SELECT sales.customer_id,
	sales.order_date,
    menu.product_name,
    menu.price,
    CASE WHEN sales.order_date >= members.join_date AND sales.customer_id=members.customer_id THEN 'Y'
    ELSE 'N'
    END AS member
FROM sales
JOIN menu
ON sales.product_id=menu.product_id
LEFT JOIN members
ON sales.customer_id=members.customer_id

-- RANK all the things
WITH joined_results AS (SELECT sales.customer_id,
	sales.order_date,
    menu.product_name,
    menu.price,
    CASE WHEN sales.order_date >= members.join_date AND sales.customer_id=members.customer_id THEN 'Y'
    ELSE 'N'
    END AS member
FROM sales
JOIN menu
ON sales.product_id=menu.product_id
LEFT JOIN members
ON sales.customer_id=members.customer_id
)

SELECT joined_results.*,
CASE WHEN member='Y' THEN
RANK() OVER (PARTITION BY member,customer_id ORDER BY order_date ASC)
ELSE Null
END AS ranking
FROM joined_results
ORDER BY customer_id,order_date,price,ranking